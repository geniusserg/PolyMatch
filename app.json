{
  "expo": {
    "name": "PolyMatch",
    "slug": "polymatch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "polymatch",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.polymatch.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan QR codes for wallet addresses",
        "NSPhotoLibraryUsageDescription": "Select images for QR scanning"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.polymatch.app",
      "permissions": ["CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow PolyMatch to access your camera for QR scanning."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
